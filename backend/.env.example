# Copy this file to .env and fill in values before starting the server.

# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REPLACE_ME_WITH_GENERATED_KEY

HOST=0.0.0.0
PORT=8000
RELOAD=true

# Comma-separated. Add your frontend dev URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

DATABASE_URL=postgresql://piemr_user:your_db_password@localhost:5432/piemr_db

SCRIPT_PATH=./piemr_assignment_upload.py

# Use full path to venv python if needed, e.g. ./.venv/bin/python
PYTHON_EXEC=python

# true = headless Chrome (required on servers without a display)
HEADLESS=false

# Leave blank to let webdriver-manager handle it automatically
CHROMEDRIVER_PATH=

SCHEDULER_TIMEZONE=Asia/Kolkata

LOG_LEVEL=INFO
